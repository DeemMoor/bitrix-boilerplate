APP_ENV=local
APP_DEBUG=true

## Удаленный сервер. Нужно только для `dl deploy`.
CATALOG_SRV=/var/www/html
USER_SRV=user
PORT_SRV=22
SERVER=127.0.0.1

## Локальный проект в DL.
HOST_NAME=bitrix-boilerplate
DOCUMENT_ROOT=/var/www/html/public

## PHP в DL v1.1.3:
## 7.3-fpm 7.4-fpm 8.0-fpm 8.1-fpm 8.2-fpm 8.3-fpm 8.4-fpm
## 7.3-apache 7.4-apache 8.0-apache 8.1-apache 8.2-apache 8.3-apache 8.4-apache
PHP_VERSION=8.4-fpm
PHP_MEMORY_LIMIT=512M
PHP_POST_MAX_SIZE=100M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_MAX_FILE_UPLOADS=50
PHP_MAX_EXECUTION_TIME=120
PHP_MODULES="opcache redis memcached"
XDEBUG=off
XDEBUG_IDE_KEY=PHPSTORM
XDEBUG_PORT=9003

## Основная база данных.
## DL явно поддерживает MySQL: 5.7 8.0 9.0.
## По умолчанию используем MySQL 8.0, потому что это самый совместимый вариант для Битрикс.
MYSQL_VERSION=8.0
MYSQL_DATABASE=db
MYSQL_USER=db
MYSQL_PASSWORD=db
MYSQL_ROOT_PASSWORD=root

## PostgreSQL в DL задается тегом официального образа postgres.
## Не включайте одновременно MYSQL_VERSION и POSTGRES_VERSION, если проекту нужна только одна база.
# POSTGRES_VERSION=15
# POSTGRES_DB=db
# POSTGRES_USER=db
# POSTGRES_PASSWORD=db

## MariaDB в DL задается тегом официального образа mariadb.
# MARIADB_VERSION=lts

## Redis и Memcached.
REDIS=true
REDIS_PASSWORD=pass
MEMCACHED=true

## Прочее окружение.
LOCALTIME=Europe/Moscow
# PHP_INI_SOURCE=.docker/php/php.ini
# NGINX_CONF=.docker/nginx/default.conf.template
# APPEND_COMPOSE_FILE=.docker/docker-compose-dl.yaml

## Настройки `dl deploy`.
EXCLUDED_TABLES=b_event_log,b_search_content_stem,b_search_content,b_search_content_text,b_search_content_title,b_search_phrase,b_search_suggest,b_perf_error
EXCLUDED_FILES=.git,upload,bitrix/backup,bitrix/cache,bitrix/managed_cache,bitrix/stack_cache,bitrix/tmp,.env
